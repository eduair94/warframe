# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/warframe

# API Configuration
API_URL=http://localhost:3529

# Proxy Configuration
PROXY_API_KEY=your_proxyscrape_api_key_here
PROXY_TYPE=http
PROXY_LESS=false
PROXY_TYPE_REGION=usa

# ProxyScrape v4 "datacenter_shared" authenticated pool (PRIMARY proxy source).
# ~3500 per-proxy user:pass datacenter IPs that authenticate off-whitelist and
# get past Cloudflare on api.warframe.market (the unauthenticated local/v2 pools
# get 403'd). When both values are set they take priority over PROXY_API_KEY and
# the local pool; if unset, the legacy sources are used.
# PROXYSCRAPE_SUBS is a comma-separated list of subscription IDs.
PROXYSCRAPE_API_TOKEN=your_proxyscrape_v4_api_token_here
PROXYSCRAPE_SUBS=sub_id_1,sub_id_2
# Optional: pool re-fetch interval in ms (default 600000 = 10 min)
PROXYSCRAPE_DC_TTL_MS=600000

# Server Configuration
API_PORT=3529
FRONTEND_PORT=3312

# reCAPTCHA Configuration (optional)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
