# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/warframe
MONGODB_MAX_POOL_SIZE=20
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# API Configuration
API_URL=http://localhost:3529

# Proxy Configuration
PROXY_API_KEY=your_proxyscrape_api_key_here
PROXY_TYPE=http
PROXY_LESS=false
PROXY_TYPE_REGION=usa

# ProxyScrape v4 "datacenter_shared" authenticated pool (PRIMARY proxy source).
# ~3500 per-proxy user:pass datacenter IPs that authenticate off-whitelist and
# get past Cloudflare on api.warframe.market (the unauthenticated local/v2 pools
# get 403'd). When both values are set they take priority over PROXY_API_KEY and
# the local pool; if unset, the legacy sources are used.
# PROXYSCRAPE_SUBS is a comma-separated list of subscription IDs.
PROXYSCRAPE_API_TOKEN=your_proxyscrape_v4_api_token_here
PROXYSCRAPE_SUBS=sub_id_1,sub_id_2
# Optional: pool re-fetch interval in ms (default 600000 = 10 min)
PROXYSCRAPE_DC_TTL_MS=600000

# Server Configuration
API_PORT=3529
FRONTEND_PORT=3312

# reCAPTCHA Configuration (optional)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Debug logging: "true" or "warframe:*" both enable verbose logs
DEBUG=false

# Admin token required to call GET /build_relics (triggers a real DB sync).
# Leave unset to rely on the built-in rate limit only.
ADMIN_SYNC_TOKEN=

# --- Real-time live feed (warframe-live process) ---
LIVE_PORT=3530
# socket | poller | off  (poller = reliable near-real-time floor; socket = spike upgrade)
LIVE_FEED_MODE=poller
LIVE_MAX_SUBSCRIPTIONS=150
LIVE_POLL_INTERVAL_MS=6000
# items fetched in parallel per poll sweep (fast sweep = frequent updates)
LIVE_POLL_CONCURRENCY=12
LIVE_PLATFORM=pc
# comma-separated allowed origins for the Socket.IO server (blank = allow all)
LIVE_CORS_ORIGIN=
# comma-separated url_names to keep live even with no viewers
LIVE_HOT_FLOOR=
# consume wf.market's public live socket (new-orders firehose -> /live market pulse). off to disable
LIVE_NEWORDERS=on
# fair-value / verdict tuning (safe defaults; leave blank to use them)
LIVE_FV_HALF_VOLUME=50
LIVE_BASE_BAND_PCT=0.08
LIVE_MAX_BAND_PCT=0.25
LIVE_CONF_MIN=0.25
# 48h trade volume below this -> item flagged thin/rig-risk and held (never advised)
LIVE_THIN_VOLUME=3
LIVE_FV_REFRESH_MS=600000
# public URL of the live Socket.IO server the Nuxt 4 app connects to (env LIVE_URL ->
# runtimeConfig.public.liveURL). Point at the Cloudflare Tunnel origin in production.
LIVE_URL=http://localhost:3530
# dedicated wf.market account for the socket spike (Phase B). Programmatic login is
# unreliable through Cloudflare; the reliable path is pasting cookies exported from a
# logged-in browser session of this account.
WARFRAME_EMAIL=
WARFRAME_PASWORD=
WARFRAME_JWT=
WARFRAME_CF_CLEARANCE=

